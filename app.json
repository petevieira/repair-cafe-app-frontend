{
  "expo": {
    "name": "RepairCafeMobile",
    "slug": "RepairCafeMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/RCM-favicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/RepairCafeMobile-large.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.RepairCafeMobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/RCM-favicon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./favicon.png",
      "bundler": "metro"
    }
  }
}
